{
  "name": "critiq",
  "displayName": "critiq \u2014 AI Code Reviewer",
  "description": "AI-powered code review in VS Code: catch security issues, bugs, and antipatterns before you push. Powered by Claude, OpenAI, or local Ollama.",
  "version": "1.2.0",
  "publisher": "faw21",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "ai",
    "code review",
    "git",
    "security",
    "claude",
    "openai",
    "ollama",
    "linter"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/faw21/critiq-vscode"
  },
  "homepage": "https://github.com/faw21/critiq-vscode",
  "bugs": {
    "url": "https://github.com/faw21/critiq-vscode/issues"
  },
  "license": "MIT",
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "critiq.reviewStaged",
        "title": "critiq: Review Staged Changes",
        "icon": "$(eye)"
      },
      {
        "command": "critiq.reviewBranch",
        "title": "critiq: Review Changes vs Branch",
        "icon": "$(git-compare)"
      },
      {
        "command": "critiq.reviewFile",
        "title": "critiq: Review Current File",
        "icon": "$(file-code)"
      },
      {
        "command": "critiq.clearDiagnostics",
        "title": "critiq: Clear All Diagnostics",
        "icon": "$(clear-all)"
      },
      {
        "command": "critiq.fixFile",
        "title": "critiq: Fix All Issues in File",
        "icon": "$(wrench)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "critiq",
          "title": "critiq",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "critiq": [
        {
          "id": "critiqFindings",
          "name": "Findings",
          "icon": "$(shield)",
          "contextualTitle": "critiq Findings"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "critiqFindings",
        "contents": "No critiq findings yet.\n\nRun a review to see AI-powered code analysis results here.\n\n[Review Staged Changes](command:critiq.reviewStaged)\n[Review Current File](command:critiq.reviewFile)"
      }
    ],
    "configuration": {
      "title": "critiq",
      "properties": {
        "critiq.provider": {
          "type": "string",
          "enum": [
            "claude",
            "openai",
            "ollama"
          ],
          "default": "claude",
          "description": "LLM provider to use for code review"
        },
        "critiq.model": {
          "type": "string",
          "default": "",
          "description": "Model name override (leave empty to use provider default)"
        },
        "critiq.focus": {
          "type": "string",
          "enum": [
            "all",
            "security",
            "performance",
            "readability",
            "correctness",
            "style"
          ],
          "default": "all",
          "description": "Focus area for reviews"
        },
        "critiq.severity": {
          "type": "string",
          "enum": [
            "",
            "critical",
            "warning",
            "info",
            "suggestion"
          ],
          "default": "",
          "description": "Minimum severity to show (leave empty to show all)"
        },
        "critiq.binaryPath": {
          "type": "string",
          "default": "critiq",
          "description": "Path to the critiq binary (default: uses PATH)"
        },
        "critiq.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key (overrides ANTHROPIC_API_KEY env var)"
        },
        "critiq.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key (overrides OPENAI_API_KEY env var)"
        },
        "critiq.autoReviewOnStage": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run review when files are saved"
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "critiq.reviewFile",
          "group": "navigation",
          "when": "resourceScheme == file"
        }
      ],
      "editor/context": [
        {
          "command": "critiq.fixFile",
          "group": "1_modification",
          "when": "resourceScheme == file"
        }
      ],
      "scm/title": [
        {
          "command": "critiq.reviewStaged",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "critiq.reviewStaged",
          "when": "view == critiqFindings",
          "group": "navigation"
        },
        {
          "command": "critiq.clearDiagnostics",
          "when": "view == critiqFindings",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "critiq.reviewStaged",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTests.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  }
}